{
  "manifest_version": 3,
  "name": "Watchparty Bridge",
  "version": "0.1.0",
  "description": "Sync video playback on any website with your watchparty room.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Watchparty"
  }
}
