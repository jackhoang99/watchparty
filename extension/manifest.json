{
  "manifest_version": 3,
  "name": "watchparty",
  "version": "1.0.0",
  "description": "Sync video playback on any website with your watchparty room. Watch together, stay close.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "watchparty"
  }
}
